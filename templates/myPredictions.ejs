<%- include('partials/header', { user }) %>
<div class="container">
  <h1>My Predictions</h1>
  <h3>Welcome, <%= user.username %></h3>

  <% if (predictions.length === 0) { %>
    <div class="card">
      <p>You haven't made any predictions yet.</p>
      <a href="/predictions/new" class="btn" style="margin-top:16px;display:inline-block;">Make Your First Prediction</a>
    </div>
  <% } else { %>
    <div class="card" style="padding:0;overflow:hidden;">
      <table class="predictions-table">
        <thead>
          <tr>
            <th>Match</th>
            <th>Predicted Score</th>
            <th>Notes</th>
            <th>Submitted</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% predictions.forEach(p => { %>
            <tr>
              <td><a href="/matches/<%= p.matchId %>" style="color:#fff;text-decoration:none;font-weight:600;"><%= p.homeTeam %> vs <%= p.awayTeam %></a></td>
              <td style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:2px;color:#ffd700;">
                <%= p.predictedHomeScore %> &ndash; <%= p.predictedAwayScore %>
              </td>
              <td style="color:rgba(255,255,255,0.5);font-size:0.85rem;"><%= p.notes || '—' %></td>
              <td style="color:rgba(255,255,255,0.4);font-size:0.85rem;"><%= new Date(p.submittedAt).toLocaleDateString() %></td>
              <td><a href="/predictions/<%= p._id %>/edit" class="btn btn-secondary" style="padding:5px 14px;font-size:0.75rem;">Edit</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div style="margin-top:16px;">
      <a href="/predictions/new" class="btn">Make Another Prediction</a>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
