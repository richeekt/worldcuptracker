<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>World Cup 2026 Explorer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;600;700&family=Oswald:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav>
    <a href="/" class="brand">WC<span>2026</span></a>
    <a href="/matches/dashboard">Matches</a>
    <a href="/teams">Teams</a>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/predictions/new">Predict</a>
      <a href="/predictions/mine">My Predictions</a>
      <a href="/auth/logout">Logout (<%= user.username %>)</a>
    <% } else { %>
      <a href="/auth/login">Login</a>
      <a href="/auth/signup">Sign Up</a>
    <% } %>
  </nav>
