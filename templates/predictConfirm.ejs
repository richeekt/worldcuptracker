<%- include('partials/header', { user }) %>
<div class="container">
  <div class="card" style="max-width:560px;margin:0 auto;">
    <p class="success-msg">Your prediction has been saved!</p>
    <h1>Prediction Confirmed</h1>
    <div style="margin-top:20px;display:flex;flex-direction:column;gap:10px;">
      <div class="match-card" style="flex-direction:column;align-items:flex-start;">
        <div class="teams"><%= prediction.homeTeam %> vs <%= prediction.awayTeam %></div>
        <div style="margin-top:8px;font-size:1.1rem;">
          Predicted Score: <strong style="color:#ffd700;"><%= prediction.predictedHomeScore %> &ndash; <%= prediction.predictedAwayScore %></strong>
        </div>
        <% if (prediction.notes) { %>
          <div style="margin-top:8px;color:#aac4e0;font-size:0.9rem;">"<%= prediction.notes %>"</div>
        <% } %>
        <div class="meta" style="margin-top:8px;">Submitted by <%= prediction.username %> on <%= new Date(prediction.submittedAt).toLocaleDateString() %></div>
      </div>
    </div>
    <div style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap;">
      <a href="/predictions/new" class="btn">Make Another Prediction</a>
      <a href="/predictions/mine" class="btn" style="background-color:#1a3d6b;">My Predictions</a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
