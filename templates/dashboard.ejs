<%- include('partials/header', { user }) %>
<div class="container">
  <div class="section-header">
    <h1>Match Dashboard</h1>
    <span class="section-tag">WC 2026</span>
  </div>

  <% STAGE_ORDER.forEach(stage => { %>
    <% if (grouped[stage]) { %>
      <div class="stage-section">
        <div class="stage-title"><%= STAGE_LABELS[stage] %></div>

        <% Object.keys(grouped[stage]).forEach(subKey => { %>
          <div class="matchday-label"><%= subKey %></div>
          <div class="match-grid" style="margin-bottom:16px;">
            <% grouped[stage][subKey].forEach(match => { %>
              <a href="/matches/<%= match.id %>" class="match-card match-card-link">
                <div>
                  <div class="teams">
                    <% if (match.homeTeam.crest) { %><img src="<%= match.homeTeam.crest %>" class="team-crest-sm" alt="" /><% } %>
                    <%= match.homeTeam.name || 'TBD' %>
                    <span style="color:rgba(255,255,255,0.3);margin:0 8px;">vs</span>
                    <%= match.awayTeam.name || 'TBD' %>
                    <% if (match.awayTeam.crest) { %><img src="<%= match.awayTeam.crest %>" class="team-crest-sm" alt="" /><% } %>
                  </div>
                  <% if (match.group) { %>
                    <div class="meta">Group <%= match.group.replace('GROUP_','') %></div>
                  <% } %>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                  <% if (match.score.fullTime.home !== null) { %>
                    <div style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:2px;color:#ffd700;">
                      <%= match.score.fullTime.home %> &ndash; <%= match.score.fullTime.away %>
                    </div>
                  <% } else { %>
                    <div class="meta"><%= new Date(match.utcDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></div>
                    <span class="status"><%=
                      match.status === 'TIMED' || match.status === 'SCHEDULED' ? 'Upcoming' :
                      match.status === 'IN_PLAY' ? 'Live' :
                      match.status === 'PAUSED' ? 'Half Time' :
                      match.status === 'FINISHED' ? 'Full Time' :
                      match.status === 'POSTPONED' ? 'Postponed' :
                      match.status === 'SUSPENDED' ? 'Suspended' :
                      match.status === 'CANCELLED' ? 'Cancelled' : match.status
                    %></span>
                  <% } %>
                </div>
              </a>
            <% }) %>
          </div>
        <% }) %>
      </div>
    <% } %>
  <% }) %>
</div>
<%- include('partials/footer') %>
